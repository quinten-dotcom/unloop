{
	"appId": "app.unloop.app",
	"appName": "Unloop",
	"webDir": "dist",
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"SplashScreen": {
			"launchShowDuration": 0,
			"backgroundColor": "#FFFFFF",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "Dark",
			"backgroundColor": "#FFFFFF"
		}
	},
	"ios": {
		"contentInset": "automatic"
	},
	"packageClassList": [
		"PushNotificationsPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
